# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartsoko?schema=public"

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002,https://smartsoko.vercel.app"

# JWT (for auth - optional for MVP)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google Maps (optional - for Places sync)
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable: Places API, Maps JavaScript API, Places Autocomplete API
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACES_API_KEY=""

# M-Pesa Daraja (optional - for payments)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""
MPESA_ENV="sandbox"

# Firebase (optional - for auth)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
